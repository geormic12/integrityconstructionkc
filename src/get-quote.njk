---
layout: base.njk
pageTitle: "Get A Quote"
description: "Request a free fencing quote from Integrity Construction KC. Fill out our quick form and we'll get back to you promptly."
permalink: /get-quote/
---

<section class="page-hero">
  <div class="hero-overlay">
    <div class="hero-content">
      <h1>We pride ourselves in making it easy for you</h1>
    </div>
  </div>
</section>

<section class="content-section">
  <div class="container">
    <div class="quote-intro">
      <h2>Fill out this quick form and we can get you a quote.</h2>
      <p>We value clear communication and understanding your unique requirements to deliver the best possible results. Let us handle the logistics while you sit back and watch your vision come to life.</p>
      <ul class="contact-list">
        <li><strong>Email:</strong> <a href="mailto:{{ site.email }}">{{ site.email }}</a></li>
        <li><strong>Phone:</strong> <a href="tel:{{ site.phonePlain }}">{{ site.phone }}</a></li>
      </ul>
    </div>

    <form class="quote-form" onsubmit="event.preventDefault(); alert('Thank you for your quote request. Please call or email us directly for the fastest response.');">
      <div class="form-group">
        <label for="quote-name">Name <span class="required">*</span></label>
        <input type="text" id="quote-name" name="name" required>
      </div>

      <div class="form-group">
        <label for="quote-email">Email <span class="required">*</span></label>
        <input type="email" id="quote-email" name="email" required>
      </div>

      <div class="form-group">
        <label for="quote-phone">Phone</label>
        <input type="tel" id="quote-phone" name="phone">
      </div>

      <div class="form-group">
        <label for="quote-style">Style of Fence</label>
        <select id="quote-style" name="style">
          <option value="">-- Select a style --</option>
          <option value="privacy">Privacy</option>
          <option value="wrought-iron">Wrought Iron</option>
          <option value="chain-link">Chain Link</option>
          <option value="spaced-picket">Spaced Picket</option>
          <option value="specialty">Specialty</option>
        </select>
      </div>

      <div class="form-group">
        <label for="quote-linear-feet">How many linear feet?</label>
        <input type="number" id="quote-linear-feet" name="linear_feet" min="0">
      </div>

      <div class="form-group">
        <label for="quote-gates">How many gates?</label>
        <input type="number" id="quote-gates" name="gates" min="0">
      </div>

      <div class="form-group form-group-checkbox">
        <label>
          <input type="checkbox" id="quote-demo" name="demolition" onchange="document.getElementById('demo-feet-group').style.display = this.checked ? 'block' : 'none';">
          Is demolition required?
        </label>
      </div>

      <div class="form-group" id="demo-feet-group" style="display: none;">
        <label for="quote-demo-feet">If demolition required, how many feet?</label>
        <input type="number" id="quote-demo-feet" name="demolition_feet" min="0">
      </div>

      <div class="form-group">
        <label for="quote-address">Address fence will be built</label>
        <input type="text" id="quote-address" name="address">
      </div>

      <div class="form-group">
        <label for="quote-details">Any additional details?</label>
        <textarea id="quote-details" name="details" rows="5"></textarea>
      </div>

      <button type="submit" class="btn btn-primary">Send</button>
    </form>
  </div>
</section>
